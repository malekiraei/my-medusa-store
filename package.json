{
  "name": "my-medusa-store",
  "private": true,
  "packageManager": "pnpm@10.11.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "test": "turbo test",
    "backend:seed": "turbo seed --filter=@dtc/backend",
    "backend:dev": "turbo dev --filter=@dtc/backend",
    "storefront:dev": "turbo dev --filter=@dtc/storefront"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.5",
      "@types/react-dom": "19.0.5"
    }
  },
  "devDependencies": {
    "@medusajs/eslint-plugin": "^2.17.0",
    "eslint": "^9.39.4",
    "jiti": "^2.7.0",
    "prettier": "^3.2.5",
    "turbo": "^2.0.14"
  },
  "workspaces": [
    "apps/*"
  ],
  "dependencies": {
    "@mantine/core": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@react-aria/breadcrumbs": "^3.6.1",
    "@react-aria/button": "^3.15.1",
    "@react-aria/checkbox": "^3.17.1",
    "@react-aria/datepicker": "^3.17.1",
    "@react-aria/i18n": "^3.13.1",
    "@react-aria/interactions": "^3.28.1",
    "@react-aria/overlays": "^3.32.1",
    "@react-aria/progress": "^3.5.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "medusa-premium-recovery": "^0.0.1",
    "react-aria": "3.50.0",
    "recharts": "^3.9.0"
  }
}
